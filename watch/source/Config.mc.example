// Copy to Config.mc and fill in your values.
// Config.mc is gitignored — it is generated by the setup skill or filled in manually.
// Run: cp watch/source/Config.mc.example watch/source/Config.mc
// Then edit the constants below before building.

module Config {

    // Tunnel URL from `npx claude-code-tracker start` (or print-build-config)
    const DAEMON_URL = "https://REPLACE_WITH_TUNNEL_URL";

    // Bearer key from `npx claude-code-tracker pair`
    const BEARER_KEY = "REPLACE_WITH_BEARER_KEY";

    // How often to poll the daemon (milliseconds). 2000 = 2 Hz.
    const POLL_INTERVAL_MS = 2000;

    // Set to false to suppress heart-rate recording on the activity (opt-out).
    const INCLUDE_PHYSIOLOGY = true;

    // Cloudflare Access headers (optional — set to true only if you configured CF Access).
    const INCLUDE_CF_ACCESS = false;
    const CF_ACCESS_CLIENT_ID = "";
    const CF_ACCESS_CLIENT_SECRET = "";

    const VERSION = "0.1.0";
}
